{
  "name": "@bingran/mews",
  "version": "0.3.1",
  "description": "A local GitHub notification daemon that scopes work to allow-listed repos and dispatches local coding agents.",
  "homepage": "https://github.com/bingran-you/mews#readme",
  "bugs": {
    "url": "https://github.com/bingran-you/mews/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bingran-you/mews.git"
  },
  "keywords": [
    "mews",
    "github",
    "notifications",
    "daemon",
    "codex",
    "claude-code"
  ],
  "type": "module",
  "bin": {
    "mews": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsdown",
    "e2e:live": "pnpm build && node ./scripts/live-e2e.mjs",
    "e2e:live:install-browser": "playwright install chromium",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm build && pnpm typecheck && pnpm test"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "playwright": "^1.53.2",
    "tsdown": "^0.21.10",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "ink": "^7.0.0",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.5",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
